# ── Servidor ──────────────────────────────────────────────
# Porta local (Render sobrescreve automaticamente com a dele)
PORT=3001

# Ambiente: development | production
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
# URL do frontend (sem barra no final)
# Dev:  http://localhost:3002
# Prod: https://seu-app.vercel.app
FRONTEND_URL=http://localhost:3002

# ── Banco de dados ─────────────────────────────────────────
# Render → seu banco PostgreSQL → "Internal Database URL"
# Formato: postgresql://usuario:senha@host/nome_do_banco
# Deixe vazio para rodar sem banco (usa mock em memória)
DATABASE_URL=postgresql://user:senha@host/dbname

# ── Autenticação (JWT) ─────────────────────────────────────
# Segredo para assinar os tokens JWT do staff
# Gere um valor seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-em-producao
